# Секрет подписи JWT. В проде — длинная случайная строка:
#   openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email-адреса администраторов (через запятую).
# auth-service кладёт role=admin в токен при логине этих пользователей.
ADMIN_EMAILS=admin@example.com

# Время жизни токенов
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# RabbitMQ (события stats -> user-profile)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Кэш ответов Open-Meteo в weather-service, секунды (опционально)
# WEATHER_CACHE_TTL_SECONDS=600
