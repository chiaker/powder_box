# Секрет подписи JWT. В проде — длинная случайная строка:
#   openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email-адреса администраторов (через запятую).
# auth-service кладёт role=admin в токен при логине этих пользователей.
ADMIN_EMAILS=admin@example.com

# Время жизни токенов
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# RabbitMQ (события stats -> user-profile, email.send -> notification)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Кэш ответов Open-Meteo в weather-service, секунды (опционально)
# WEATHER_CACHE_TTL_SECONDS=600

# Базовый URL сайта — попадает в ссылки в письмах (подтверждение email)
PUBLIC_BASE_URL=http://localhost:3000

# SMTP для notification-service. Дефолты — dev-заглушка mailpit
# (письма видны на http://localhost:8025). В проде укажи реальный SMTP.
# SMTP_TLS: none | starttls | ssl
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@powderbox.local
SMTP_TLS=none

# Период проверки снежных алертов, секунды (0 = выключить)
# SNOW_ALERT_CHECK_INTERVAL_SECONDS=21600
